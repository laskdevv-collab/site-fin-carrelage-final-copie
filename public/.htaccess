# ========================================
# Configuration SEO - Force HTTPS
# ========================================

RewriteEngine On

# Force la redirection HTTPS
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ========================================
# Gestion du Favicon (icon.ico)
# ========================================

# Redirection interne pour s'assurer que /favicon.ico pointe vers votre nouveau /images/icon.ico
# Cela aide les vieux robots à trouver votre icône sans erreur 404
## Rediriger le favicon vers le fichier `icon.ico`
## Assurez-vous d'avoir uploadé `icon.ico` dans /images
RewriteRule ^favicon\.ico$ /images/icon.ico [L,R=301]

## Définir des en-têtes pour forcer la revalidation du favicon (mod_headers requis)
<IfModule mod_headers.c>
  <FilesMatch "\.(ico)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 01 Jan 1970 00:00:00 GMT"
  </FilesMatch>
</IfModule>

# ========================================
# Optimisations SEO supplémentaires
# ========================================

# Supprime le slash final
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ========================================
# Sécurité
# ========================================

Options -Indexes

<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ========================================
# Performance et Cache
# ========================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images (Général)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  # FAVICON : On réduit à 1 heure temporairement pour forcer la mise à jour partout
  # Pour forcer une revalidation rapide du favicon côté client
  ExpiresByType image/x-icon "access plus 0 seconds"
  ExpiresByType image/vnd.microsoft.icon "access plus 0 seconds"
  
  # CSS et JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  
  # HTML
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>